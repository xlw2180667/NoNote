    "#cannotConnectToICloud" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cannot connect to your iCloud, please check your connection. You can still use NoDiary without iCloud connection. All Your diaries will be saved on your phone. But you will lose them if you deleted the app or when your disk is full."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法连接到您的iCloud，请检查您的连接。如果您不希望使用iCloud服务，您仍然可以使用NoDiary，您的日记会被储存在手机硬盘内。但如果您删除了NoDiary或者硬盘空间不足时，您会丢失您的日记。"
          }
        }
      }
    },
